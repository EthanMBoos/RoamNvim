font-family = "JetBrainsMono Nerd Font"
font-size   = 14
theme       = "Catppuccin Mocha"
scrollback-limit = 10000

# Don't dim inactive splits (default 0.7 fades unfocused panes)
unfocused-split-opacity = 1

# Disable resize overlay indicator
resize-overlay = never

# Cross-platform keybinds (ctrl+shift matches Linux terminal convention)
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface

# Tab switching
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

# Pane management — Ctrl+A prefix (tmux convention, doesn't conflict with Neovim's Ctrl+W)
# Ctrl+A is free because terminal readline uses Ctrl+A for "start of line" which vi mode overrides
keybind = ctrl+a>backslash=new_split:right
keybind = ctrl+a>minus=new_split:down
keybind = ctrl+a>x=close_surface

# Pane resize — direct chord (no prefix) so holding the key repeats and the split glides.
# ctrl+shift = "Ghostty owns this layer" (same convention as copy/paste/tab above).
# Neovim gets ctrl+shift+hjkl instead (Ghostty passes those through), which keeps the
# two layers on separate chords — a shared resize chord can't work because resize_split
# is always "performable" and Ghostty would eat it inside Neovim (see docs/ghostty-resize-performable-bug.md).
# (Arrows here rather than hjkl because macOS steals ctrl+arrows, but ctrl+shift+arrows is free.)
keybind = ctrl+shift+arrow_left=resize_split:left,10
keybind = ctrl+shift+arrow_right=resize_split:right,10
keybind = ctrl+shift+arrow_up=resize_split:up,10
keybind = ctrl+shift+arrow_down=resize_split:down,10

# Pane navigation — unified with Neovim window nav (ctrl+h/j/k/l)
# performable: fires if a Ghostty split exists in that direction, otherwise passes through to Neovim
keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right
