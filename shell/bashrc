# vi mode — esc to enter normal mode, k/j for history, h/l/w/b to move, v to edit in nvim
set -o vi

# fzf — fuzzy history picker (ctrl+r), file picker (ctrl+t)
if command -v fzf &>/dev/null; then
  # Ubuntu's apt-installed fzf uses these source files instead of --bash flag
  [ -f /usr/share/doc/fzf/examples/key-bindings.bash ] && source /usr/share/doc/fzf/examples/key-bindings.bash
  [ -f /usr/share/doc/fzf/examples/completion.bash ] && source /usr/share/doc/fzf/examples/completion.bash
else
  bind '"\C-r": reverse-search-history'
fi
